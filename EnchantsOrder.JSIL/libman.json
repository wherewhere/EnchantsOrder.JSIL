{
  "version": "3.0",
  "defaultProvider": "jsdelivr",
  "libraries": [
    {
      "library": "jquery@latest",
      "files": [
        "dist/jquery.slim.min.js",
        "dist/jquery.slim.min.map"
      ],
      "destination": "wwwroot/lib/jquery/"
    },
    {
      "library": "lz-string@latest",
      "files": [
        "libs/lz-string.min.js"
      ],
      "destination": "wwwroot/lib/lz-string/"
    },
    {
      "library": "url-search-params-polyfill@latest",
      "files": [
        "index.min.js"
      ],
      "destination": "wwwroot/lib/url-search-params-polyfill/"
    },
    {
      "library": "winjs@latest",
      "files": [
        "css/ui-dark.min.css",
        "fonts/Symbols.ttf",
        "js/base.js",
        "js/base.min.js",
        "js/base.min.js.map",
        "js/ui.js",
        "js/ui.min.js",
        "js/ui.min.js.map"
      ],
      "destination": "wwwroot/lib/winjs/"
    }
  ]
}